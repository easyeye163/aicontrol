    <!-- Guide -->
    <string name="guide_page_title">权限设置</string>
    <string name="guide_page_subtitle">请开启以下权限以确保应用正常工作</string>
    <string name="guide_skip">跳过</string>
    <string name="guide_start">开始使用</string>
    <string name="guide_title_accessibility">无障碍服务</string>
    <string name="guide_desc_accessibility">这是 AI 控制设备的核心权限。\n\n1. 进入 设置 → 无障碍 → 已下载的应用\n2. 在列表中找到 "AiControl"\n3. 打开开关\n4. 在系统对话框中确认</string>
    <string name="guide_title_notification">常驻通知</string>
    <string name="guide_desc_notification">保持应用在后台运行，防止被系统杀死。\n\n直接点击首页卡片即可开启。Android 13+ 会先请求通知权限。</string>
    <string name="guide_title_overlay">悬浮窗权限</string>
    <string name="guide_desc_overlay">显示 AI 执行状态的悬浮面板。\n\n1. 进入 设置 → 应用 → AiControl\n2. 找到 "显示在其他应用上层"\n3. 打开开关</string>
    <string name="guide_title_battery">电池白名单</string>
    <string name="guide_desc_battery">防止系统在后台停止应用。\n\n点击首页卡片，然后在系统对话框中确认"允许"。（部分设备可能需要设置为"无限制"）</string>
    <string name="guide_title_storage">文件访问</string>
    <string name="guide_desc_storage">允许 AI 读写设备上的文件。\n\nAndroid 11+：进入 设置 → 开启 "所有文件访问权限"\nAndroid 10 及以下：在弹窗中授予权限</string>

