<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera FPV display (left eye for VR mode) -->
    <com.aicontrol.android.aircam.view.DisplayImage
        android:id="@+id/ivLeftImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1a1a1a" />

    <!-- WiFi not connected status overlay -->
    <LinearLayout android:id="@+id/lyWifiStatus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:background="#55000000">

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="\u2601 WiFi Camera"
            android:textSize="22sp" android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="\u8BF7\u8FDE\u63A5\u65E0\u4EBA\u673AWiFi\u70ED\u70B9"
            android:textSize="14sp" android:textColor="#888888" />
    </LinearLayout>

    <!-- Camera FPV display (right eye for VR mode) -->
    <com.aicontrol.android.aircam.view.DisplayImage
        android:id="@+id/ivRightImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Zoom/pinch view for camera preview -->
    <com.aicontrol.android.aircam.view.ZoomView
        android:id="@+id/lyZoomView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Virtual rudder (joystick overlay) -->
    <com.aicontrol.android.aircam.view.rudder.Rudder
        android:id="@+id/playRudder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Scale value text -->
    <TextView android:id="@+id/tvScaleValue"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:textSize="14sp" android:textColor="#FFFFFF"
        android:visibility="gone" />

    <!-- Voice recognition word display -->
    <TextView android:id="@+id/tvVoiceWord"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:textSize="16sp" android:textColor="#FFFFFF"
        android:visibility="gone" />

    <!-- Top header bar with buttons -->
    <LinearLayout android:id="@+id/ly_head_second"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#44000000">

        <ImageView android:id="@+id/btnPlayBack"
            android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back_white"
            android:padding="8dp" />

        <ImageView android:id="@+id/btnVrPlay"
            android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" />

        <ImageView android:id="@+id/btnCameraSwitch"
            android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" />

        <ImageView android:id="@+id/btnPlayRoate"
            android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" />

        <ImageView android:id="@+id/btnChangeOrientation"
            android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" />

        <View android:layout_width="0dp" android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView android:id="@+id/img_video_mp3"
            android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" />

        <ImageView android:id="@+id/btnMp3Switch"
            android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" />

        <ImageView android:id="@+id/btnPlayReturn"
            android:layout_width="40dp" android:layout_height="40dp"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Left horizontal slider -->
    <com.aicontrol.android.aircam.view.slider.SliderHor
        android:id="@+id/playLeftSlider"
        android:layout_width="wrap_content" android:layout_height="40dp"
        android:layout_gravity="bottom|left"
        android:layout_marginLeft="20dp"
        android:layout_marginBottom="160dp"
        android:visibility="gone" />

    <!-- Right horizontal slider -->
    <com.aicontrol.android.aircam.view.slider.SliderHor
        android:id="@+id/playRightSlider"
        android:layout_width="wrap_content" android:layout_height="40dp"
        android:layout_gravity="bottom|right"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="160dp"
        android:visibility="gone" />

    <!-- Center vertical slider (throttle) -->
    <com.aicontrol.android.aircam.view.slider.SliderVer
        android:id="@+id/playCenterSlider"
        android:layout_width="40dp" android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|right"
        android:layout_marginRight="10dp"
        android:visibility="gone" />

    <!-- Bottom slider container -->
    <LinearLayout android:id="@+id/lySliderBottom"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:visibility="gone" />

    <!-- Center slider container -->
    <RelativeLayout android:id="@+id/lySliderCenter"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|right"
        android:visibility="gone" />

    <!-- Emergency stop container -->
    <RelativeLayout android:id="@+id/lyMengencyStop"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Recording time indicator -->
    <LinearLayout android:id="@+id/ly_record_time"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|right"
        android:layout_marginTop="60dp"
        android:layout_marginRight="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView android:id="@+id/ivRecordIcon"
            android:layout_width="16dp" android:layout_height="16dp" />

        <TextView android:id="@+id/tvRecordTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#FF0000" />
    </LinearLayout>

    <!-- Auto photo indicator -->
    <TextView android:id="@+id/tvAutoPhoto"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|left"
        android:layout_marginTop="60dp"
        android:layout_marginLeft="10dp"
        android:textSize="12sp" android:textColor="#FFFFFF"
        android:visibility="gone" />

    <!-- Loading indicator -->
    <ImageView android:id="@+id/ivLoading"
        android:layout_width="60dp" android:layout_height="60dp"
        android:layout_gravity="center"
        android:src="@mipmap/ic_stub"
        android:visibility="gone" />

    <!-- Round move indicator -->
    <ImageView android:id="@+id/ivRoundMove"
        android:layout_width="40dp" android:layout_height="40dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Right-side control buttons column -->
    <LinearLayout
        android:layout_width="50dp" android:layout_height="wrap_content"
        android:layout_gravity="right|center_vertical"
        android:layout_marginRight="10dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:dividerPadding="2dp"
        android:showDividers="middle">

        <ImageView android:id="@+id/btnPlayRecord"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlaySnap"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlaySpeed"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayAutoPhoto"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayLock"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayButton"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/img_filter_play"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/img_voice_control"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayRev"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayNoHead"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />
    </LinearLayout>

    <!-- Left-side control buttons column -->
    <LinearLayout
        android:layout_width="50dp" android:layout_height="wrap_content"
        android:layout_gravity="left|center_vertical"
        android:layout_marginLeft="10dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:dividerPadding="2dp"
        android:showDividers="middle">

        <ImageView android:id="@+id/btnPlayPath"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayGensor"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayStayHigh"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayOneKeyFly"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayOneKeyLand"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnMengencyStop"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />

        <ImageView android:id="@+id/btnPlayCheckout"
            android:layout_width="44dp" android:layout_height="44dp"
            android:padding="6dp" />
    </LinearLayout>

</FrameLayout>
