<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgPrimary">

    <com.aicontrol.android.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56pt"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="match_parent"
        android:layout_height="40pt"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/colorBgSecondary"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:id="@+id/tabAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/skill_tab_all"
            android:textColor="@color/colorBrandPrimary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabAutoReply"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/skill_tab_auto_reply"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tabPhoneControl"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/skill_tab_phone_control"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tabCrossApp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/skill_tab_cross_app"
            android:textColor="@color/colorTextSecondary"
            android:textSize="13sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSkills"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="12pt"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/skill_empty"
        android:textColor="@color/colorTextSecondary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvSkills"
        app:layout_constraintBottom_toBottomOf="@id/rvSkills"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="28pt"
        android:layout_height="28pt"
        android:layout_margin="12pt"
        android:src="@drawable/ic_add"
        app:fabSize="mini"
        app:fabCustomSize="28pt"
        app:maxImageSize="14pt"
        android:contentDescription="@string/skill_add"
        app:backgroundTint="@color/colorBrandPrimary"
        app:tint="@color/colorBrandOnPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>