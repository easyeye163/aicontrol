<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgPrimary">

    <com.aicontrol.android.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56pt"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutModeSwitch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12pt"
        android:paddingVertical="4pt"
        android:background="@color/colorBgSecondary"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:id="@+id/tvModeHint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextHint"
            android:textSize="10sp"
            android:layout_marginEnd="8pt"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_cloud_mode"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:layout_marginEnd="4pt" />

        <Switch
            android:id="@+id/switchCloudMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10pt" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_local_model_switch"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:layout_marginEnd="4pt" />

        <Switch
            android:id="@+id/switchLocalModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingVertical="8pt"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutModeSwitch"
        app:layout_constraintBottom_toTopOf="@id/layoutInput" />

    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12pt"
        android:paddingVertical="8pt"
        android:background="@color/colorBgSecondary"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/btnCamera"
            android:layout_width="36pt"
            android:layout_height="36pt"
            android:padding="8pt"
            android:src="@drawable/ic_camera"
            android:contentDescription="@string/chat_take_photo"
            app:tint="@color/colorTextSecondary" />

        <ImageView
            android:id="@+id/btnAttach"
            android:layout_width="36pt"
            android:layout_height="36pt"
            android:padding="8pt"
            android:src="@drawable/ic_attach"
            android:contentDescription="@string/chat_attach_image"
            app:tint="@color/colorTextSecondary" />

        <ImageView
            android:id="@+id/btnVoice"
            android:layout_width="36pt"
            android:layout_height="36pt"
            android:padding="8pt"
            android:src="@drawable/ic_mic"
            android:contentDescription="@string/chat_take_photo"
            app:tint="@color/colorTextSecondary" />

        <ImageView
            android:id="@+id/btnTts"
            android:layout_width="36pt"
            android:layout_height="36pt"
            android:padding="8pt"
            android:src="@drawable/ic_volume_off"
            android:contentDescription="TTS语音朗读"
            app:tint="@color/colorTextSecondary" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8pt"
            android:background="@drawable/bg_chat_input"
            android:paddingHorizontal="12pt"
            android:paddingVertical="8pt"
            android:hint="@string/chat_input_hint"
            android:textColorHint="@color/colorTextSecondary"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:maxLines="1"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionSend" />

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="36pt"
            android:layout_height="36pt"
            android:layout_marginStart="8pt"
            android:padding="6pt"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/chat_send"
            app:tint="@color/colorBrandPrimary" />

    </LinearLayout>

    <ImageView
        android:id="@+id/ivPreview"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="12pt"
        android:layout_marginBottom="8pt"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="@color/colorBgSecondary"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/btnRemovePreview"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_close"
        android:visibility="gone"
        app:tint="@color/colorErrorPrimary"
        app:layout_constraintTop_toTopOf="@id/ivPreview"
        app:layout_constraintEnd_toEndOf="@id/ivPreview" />

</androidx.constraintlayout.widget.ConstraintLayout>
