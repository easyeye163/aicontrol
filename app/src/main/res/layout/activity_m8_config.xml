<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBgSecondary"
    android:orientation="vertical">

    <com.aicontrol.android.widget.CommonToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56pt" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16pt"
        android:paddingTop="16pt"
        android:paddingBottom="32pt">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="16pt"
                android:text="配置 M8/H8 无人机的连接地址（基于 HY-Chip 协议）。修改后立即生效，无需重启。"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14pt" />

            <!-- Device IP Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="设备IP地址"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etM8Ip"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="192.168.100.1"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <!-- UDP Video Port -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="视频流端口 (UDP/RTSP)"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etUdpPort"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="1563"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <!-- TCP Command Port -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="指令端口 (TCP/JSON)"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etTcpPort"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="4646"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <!-- FTP Port -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="FTP文件端口"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <EditText
                    android:id="@+id/etFtpPort"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:background="@null"
                    android:hint="21"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingHorizontal="16pt"
                    android:singleLine="true"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextTertiary"
                    android:textSize="15pt" />
            </androidx.cardview.widget.CardView>

            <!-- Video URL Preview -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20pt"
                android:paddingHorizontal="4pt"
                android:paddingBottom="8pt"
                android:text="视频流地址预览"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14pt"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorContainerBrighten"
                app:cardCornerRadius="12pt"
                app:cardElevation="1pt">

                <TextView
                    android:id="@+id/tvVideoUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16pt"
                    android:paddingVertical="12pt"
                    android:text="192.168.100.1:1563"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13pt"
                    android:maxLines="2" />
            </androidx.cardview.widget.CardView>

            <com.aicontrol.android.widget.KButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48pt"
                android:layout_marginTop="32pt"
                android:text="保存配置"
                android:textSize="16pt" />

            <com.aicontrol.android.widget.KButton
                android:id="@+id/btnRestore"
                android:layout_width="match_parent"
                android:layout_height="48pt"
                android:layout_marginTop="12pt"
                android:text="恢复默认"
                app:btnBorderColor="@color/colorTextTertiary"
                app:btnTextColor="@color/colorTextSecondary"
                android:textSize="16pt" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
