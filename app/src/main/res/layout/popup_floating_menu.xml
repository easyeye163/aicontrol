<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp"
    android:background="@drawable/bg_popup_menu">

    <TextView
        android:id="@+id/tvMenuChat"
        android:layout_width="136dp"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/floating_menu_chat"
        android:textColor="#E0FFFFFF"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_chat"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_popup_menu_item" />

    <TextView
        android:id="@+id/tvMenuAnalyzeScreen"
        android:layout_width="136dp"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/floating_menu_analyze_screen"
        android:textColor="#E0FFFFFF"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_analyze_screen"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_popup_menu_item" />

    <TextView
        android:id="@+id/tvMenuToggleAvatar"
        android:layout_width="136dp"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/floating_menu_toggle_avatar"
        android:textColor="#E0FFFFFF"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_avatar_connecting"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_popup_menu_item" />

    <TextView
        android:id="@+id/tvMenuVoiceFloat"
        android:layout_width="136dp"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/floating_menu_voice_float"
        android:textColor="#E0FFFFFF"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_mic"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_popup_menu_item" />

    <TextView
        android:id="@+id/tvMenuScreenStream"
        android:layout_width="136dp"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/floating_menu_screen_stream"
        android:textColor="#E0FFFFFF"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_screen_stream"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_popup_menu_item" />

    <TextView
        android:id="@+id/tvMenuVideoStream"
        android:layout_width="136dp"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="@string/floating_menu_video_stream"
        android:textColor="#E0FFFFFF"
        android:textSize="14sp"
        android:drawableStart="@drawable/ic_video_stream"
        android:drawablePadding="10dp"
        android:background="@drawable/bg_popup_menu_item" />

</LinearLayout>
