<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:orientation="horizontal"
    android:padding="16pt">

    <!-- 左侧：控制面板 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- 顶部工具栏 -->
        <com.aicontrol.android.widget.CommonToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="48pt" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 方向控制 3x3 网格 -->
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3"
            android:useDefaultMargins="false">

            <!-- 空位 -->
            <Space android:layout_width="72pt" android:layout_height="72pt" />

            <!-- 前进 -->
            <Button
                android:id="@+id/btnForward"
                android:layout_width="72pt"
                android:layout_height="72pt"
                android:layout_column="1"
                android:layout_row="0"
                android:background="@drawable/bg_car_btn_forward"
                android:text="UP"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 空位 -->
            <Space android:layout_width="72pt" android:layout_height="72pt" />

            <!-- 左转 -->
            <Button
                android:id="@+id/btnLeft"
                android:layout_width="72pt"
                android:layout_height="72pt"
                android:layout_column="0"
                android:layout_row="1"
                android:background="@drawable/bg_car_btn_left"
                android:text="LT"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 停止 -->
            <Button
                android:id="@+id/btnStop"
                android:layout_width="72pt"
                android:layout_height="72pt"
                android:layout_column="1"
                android:layout_row="1"
                android:background="@drawable/bg_car_btn_stop"
                android:text="STOP"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 右转 -->
            <Button
                android:id="@+id/btnRight"
                android:layout_width="72pt"
                android:layout_height="72pt"
                android:layout_column="2"
                android:layout_row="1"
                android:background="@drawable/bg_car_btn_right"
                android:text="RT"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 空位 -->
            <Space android:layout_width="72pt" android:layout_height="72pt" />

            <!-- 后退 -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="72pt"
                android:layout_height="72pt"
                android:layout_column="1"
                android:layout_row="2"
                android:background="@drawable/bg_car_btn_back"
                android:text="DN"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 空位 -->
            <Space android:layout_width="72pt" android:layout_height="72pt" />

        </GridLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16pt" />

        <!-- 速度滑块 -->
        <LinearLayout
            android:layout_width="280pt"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8pt">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPD"
                android:textColor="#aaa"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/speedBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8pt"
                android:layout_marginEnd="8pt"
                android:max="100"
                android:min="10"
                android:progress="50" />

            <TextView
                android:id="@+id/tvSpeed"
                android:layout_width="32pt"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#4ade80"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- 右侧：状态面板 -->
    <LinearLayout
        android:layout_width="180pt"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="12pt"
        android:padding="16pt"
        android:background="#16213e"
        android:layout_gravity="center">

        <!-- WiFi 状态 -->
        <ImageView
            android:id="@+id/ivWifiStatus"
            android:layout_width="36pt"
            android:layout_height="36pt"
            android:src="@drawable/ic_wifi_green"
            app:tint="#666" />

        <TextView
            android:id="@+id/tvWifiStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8pt"
            android:text="Disconnected"
            android:textColor="#888"
            android:textSize="12sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="16pt" />

        <!-- 目标 IP -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.4.1"
            android:textColor="#aaa"
            android:textSize="11sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="12pt" />

        <!-- 最后指令 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last Cmd"
            android:textColor="#666"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvLastCmd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4pt"
            android:text="Ready"
            android:textColor="#4ade80"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
