<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <!-- WiFi 状态 — 顶部居中 -->
    <LinearLayout
        android:id="@+id/layoutWifiStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16pt"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16pt"
        android:paddingVertical="6pt"
        android:background="@drawable/bg_wifi_status_panel">

        <ImageView
            android:id="@+id/ivWifiStatus"
            android:layout_width="18pt"
            android:layout_height="18pt"
            android:src="@drawable/ic_wifi_green"
            app:tint="#666" />

        <TextView
            android:id="@+id/tvWifiStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8pt"
            android:text="未连接"
            android:textColor="#888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvIpAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12pt"
            android:text="192.168.4.1"
            android:textColor="#555"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- 调试日志区域 — 左上角 -->
    <ScrollView
        android:id="@+id/scrollDebugLog"
        android:layout_width="200dp"
        android:layout_height="80dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="#1e293b"
        android:padding="4dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvDebugLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#fbbf24"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="1dp" />

    </ScrollView>

    <!-- 设置按钮 — 右上角 -->
    <ImageView
        android:id="@+id/btnSettings"
        android:layout_width="28pt"
        android:layout_height="28pt"
        android:layout_gravity="top|end"
        android:layout_marginTop="16pt"
        android:layout_marginEnd="16pt"
        android:src="@drawable/ic_settings"
        android:padding="4pt"
        app:tint="#64748b" />

    <!-- 底部控制栏 — 速度显示 + 语音按钮 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="12pt"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16pt"
        android:paddingVertical="6pt"
        android:background="@drawable/bg_wifi_status_panel">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="速度"
            android:textColor="#64748b"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6pt"
            android:text="0%"
            android:textColor="#4ade80"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLastCmd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20pt"
            android:text="就绪"
            android:textColor="#475569"
            android:textSize="11sp" />

        <!-- 语音控制按钮 -->
        <TextView
            android:id="@+id/btnVoice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20pt"
            android:paddingHorizontal="12pt"
            android:paddingVertical="4pt"
            android:background="@drawable/bg_wifi_status_panel"
            android:text="🎤 语音"
            android:textColor="#94a3b8"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 核心控制区 — 三列布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="20pt"
        android:paddingTop="50pt"
        android:paddingBottom="44pt">

        <!-- 左侧摇杆 — 前后控制 -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.aicontrol.android.widget.SingleAxisJoystickView
                android:id="@+id/joystickVertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

        </FrameLayout>

        <!-- 中间 — 3D 停止按钮 -->
        <FrameLayout
            android:layout_width="100pt"
            android:layout_height="match_parent">

            <Button
                android:id="@+id/btnStop"
                android:layout_width="80pt"
                android:layout_height="80pt"
                android:layout_gravity="center"
                android:background="@drawable/bg_stop_3d_selector"
                android:text="停止"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:shadowColor="#000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3" />

        </FrameLayout>

        <!-- 右侧摇杆 — 左右转向 -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.aicontrol.android.widget.SingleAxisJoystickView
                android:id="@+id/joystickHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
