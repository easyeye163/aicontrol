<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a">

    <!-- WiFi 状态 — 顶部居中 -->
    <LinearLayout
        android:id="@+id/layoutWifiStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16pt"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16pt"
        android:paddingVertical="6pt"
        android:background="@drawable/bg_wifi_status_panel">

        <ImageView
            android:id="@+id/ivWifiStatus"
            android:layout_width="18pt"
            android:layout_height="18pt"
            android:src="@drawable/ic_wifi_green"
            app:tint="#666" />

        <TextView
            android:id="@+id/tvWifiStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8pt"
            android:text="Disconnected"
            android:textColor="#888"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvIpAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12pt"
            android:text="192.168.4.1"
            android:textColor="#555"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- 底部控制栏 — 速度显示 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="12pt"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="16pt"
        android:paddingVertical="6pt"
        android:background="@drawable/bg_wifi_status_panel">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPD"
            android:textColor="#64748b"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6pt"
            android:text="0%"
            android:textColor="#4ade80"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLastCmd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20pt"
            android:text="Ready"
            android:textColor="#475569"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- 核心控制区 — 三列布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="20pt"
        android:paddingTop="50pt"
        android:paddingBottom="44pt">

        <!-- 左侧摇杆 — 前后控制 -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.aicontrol.android.widget.SingleAxisJoystickView
                android:id="@+id/joystickVertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <!-- 前后标签 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="6pt"
                android:text="FORWARD"
                android:textColor="#475569"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="6pt"
                android:text="BACK"
                android:textColor="#475569"
                android:textSize="10sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- 中间 — 3D 停止按钮 -->
        <FrameLayout
            android:layout_width="100pt"
            android:layout_height="match_parent">

            <Button
                android:id="@+id/btnStop"
                android:layout_width="80pt"
                android:layout_height="80pt"
                android:layout_gravity="center"
                android:background="@drawable/bg_stop_3d_selector"
                android:text="STOP"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:shadowColor="#000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="3" />

        </FrameLayout>

        <!-- 右侧摇杆 — 左右转向 -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.aicontrol.android.widget.SingleAxisJoystickView
                android:id="@+id/joystickHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|left"
                android:layout_marginTop="6pt"
                android:layout_marginStart="6pt"
                android:text="LEFT"
                android:textColor="#475569"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|right"
                android:layout_marginTop="6pt"
                android:layout_marginEnd="6pt"
                android:text="RIGHT"
                android:textColor="#475569"
                android:textSize="10sp"
                android:textStyle="bold" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
