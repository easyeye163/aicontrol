<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8pt">

    <LinearLayout
        android:id="@+id/deleteLayout"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/colorErrorPrimary"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="@string/skill_delete"
            app:tint="@color/colorBrandOnPrimary" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contentCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/colorBgSecondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12pt"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8pt"
                        android:paddingHorizontal="6pt"
                        android:paddingVertical="2pt"
                        android:textColor="@color/colorBrandOnPrimary"
                        android:textSize="10sp"
                        android:background="@color/colorBrandPrimary" />

                    <TextView
                        android:id="@+id/tvBuiltIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6pt"
                        android:text="@string/skill_builtin"
                        android:textColor="@color/colorSuccessPrimary"
                        android:textSize="10sp"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4pt"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4pt"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvTriggerType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorTextHint"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvRunCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8pt"
                        android:textColor="@color/colorTextHint"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchEnable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8pt" />

            <ImageView
                android:id="@+id/btnExecute"
                android:layout_width="32pt"
                android:layout_height="32pt"
                android:layout_marginStart="8pt"
                android:padding="6pt"
                android:src="@drawable/ic_play"
                android:contentDescription="@string/skill_execute"
                app:tint="@color/colorBrandPrimary" />

            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="32pt"
                android:layout_height="32pt"
                android:layout_marginStart="8pt"
                android:padding="6pt"
                android:src="@drawable/ic_edit"
                android:contentDescription="@string/skill_edit"
                app:tint="@color/colorTextSecondary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>